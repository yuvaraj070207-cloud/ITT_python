import java.util.Scanner;

public class horsePool {

    // Generate shift table for Horspool algorithm
    public static int[] generateShiftTable(String pattern) {
        int m = pattern.length();
        int size = 256; // Size of the ASCII alphabet
        int[] table = new int[size];

        // Initialize all shifts to pattern length
        for (int i = 0; i <size; i++) {
            table[i] = m;
        }

        // Fill the shift values based on pattern characters except last
        for (int j = 0; j < m - 1; j++) {
            table[(int) pattern.charAt(j)] = m - 1 - j;
        }

        return table;
    }

    // Horspool matching algorithm implementation
    public static int horspoolMatching(String pattern, String text) {
        int[] shiftTable = generateShiftTable(pattern);
        int m = pattern.length();
        int n = text.length();
        int i = m - 1; // Position of pattern's right end in text

        while (i <= n - 1) {
            int k = 0; // Number of matched characters

            // Compare pattern characters from right to left
            while (k <= m - 1 && pattern.charAt(m - 1 - k) == text.charAt(i - k)) {
                k++;
            }

            if (k == m) {
                return i - m + 1; // Match found, return start index
            } else {
                // Shift position by value in shift table
                i += shiftTable[(int) text.charAt(i)];
            }
        }

        return -1; // No match found
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        System.out.print("Enter the text: ");
        String text = scanner.nextLine();

        System.out.print("Enter the pattern to search: ");
        String pattern = scanner.nextLine();

        int result = horspoolMatching(pattern, text);

        if (result == -1) {
            System.out.println("Pattern not found in the text.");
        } else {
            System.out.println("Pattern found at index: " + result);
        }

        scanner.close();
    }
}
